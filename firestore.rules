rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: chapters
    // Document ID: auto-generated or numeric id
    // Fields:
    //   - id: number (required)
    //   - label: string (required)
    //   - title: string (required)
    //   - content: string (required)
    //   - order: number (required)
    //
    // Collection: metadata
    // Document ID: app_state
    // Fields:
    //   - coverImage: string (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "bhavesh.kumawat@myoperator.co" && request.auth.token.email_verified == true));
    }

    function isValidChapter(data) {
      return data.keys().hasAll(['id', 'label', 'title', 'content', 'order']) &&
             data.id is number &&
             data.label is string && data.label.size() < 100 &&
             data.title is string && data.title.size() < 200 &&
             data.content is string && data.content.size() < 50000 &&
             data.order is number;
    }

    function isValidMetadata(data) {
      return !('coverImage' in data) || (data.coverImage is string && data.coverImage.size() < 2000000);
    }

    match /chapters/{chapterId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidChapter(request.resource.data);
      allow delete: if isAdmin();
    }

    match /metadata/app_state {
      allow read: if true;
      allow write: if isAdmin() && isValidMetadata(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
